{stylixColors}:
with stylixColors; {
  "comment" = {
    fg = base03;
    modifiers = ["italic"];
  };
  "constant" = base0E;
  "constant.numeric" = base0E;
  "constant.character" = base0E;
  "constant.character.escape" = base08;
  "string" = base0D;
  "string.regexp" = base09;
  "string.special" = base0C;
  "keyword" = base08;
  "keyword.control" = base08;
  "keyword.operator" = base08;
  "keyword.function" = base09;
  "operator" = base0C;
  "type" = base0A;
  "type.builtin" = base0A;
  "constructor" = base0C;
  "attribute" = base0A;
  "tag" = base0C;
  "tag.attribute" = base0A;
  "punctuation" = base04;
  "punctuation.delimiter" = base04;
  "punctuation.bracket" = base0E;
  "punctuation.special_jsx" = base0C;
  "special" = base09;
}
